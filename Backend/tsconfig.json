{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",           
    "moduleResolution": "Node16", 
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"] 
  },
  "include": ["**/*"], 
  "exclude": ["node_modules", "dist", ".git"] 
}